;; Datomic/Datascript schema for this repo's queryable .edn files (EDN
;; datomize fanout). Datomic+Datascript compatible only (no Datomic-only
;; keys like :db.install/_attribute). Generated/maintained by hand alongside
;; resources/kotoba/raytrace/config.edn -- keep in sync if that file's
;; attrs change.

[{:db/ident :bvh/leaf-max
  :db/valueType :db.type/long
  :db/cardinality :db.cardinality/one}

 {:db/ident :bvh/det-epsilon
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one}

 {:db/ident :bvh/hit-t-epsilon
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one}

 {:db/ident :bvh/extent-epsilon
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one}

 {:db/ident :bvh/morton-scale
  :db/valueType :db.type/long
  :db/cardinality :db.cardinality/one}

 {:db/ident :rt/default-config
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc "pr-str'd blob of the nested {:max-bounces :spp :clamp :seed} map -- non-scalar value, unblob on read."}]
